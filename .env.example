# Anthropic API — Claude Sonnet 4.6
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — Fellito voice (separate key, never reuse from other projects)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=REPLACE_WITH_FELLITO_VOICE_ID

# Backend server
BACKEND_URL=http://localhost:3001
BACKEND_PORT=3001

# Auth — CHANGE THESE before deploying
JWT_SECRET=change_this_to_a_long_random_string_in_production

# Owner account — bootstrapped automatically on first server start
OWNER_EMAIL=cryptofedge@gmail.com
OWNER_PASSWORD=change_this_strong_password

# App environment
NODE_ENV=development
